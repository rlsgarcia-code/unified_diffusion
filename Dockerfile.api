FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV UDIFF_CACHE_DIR=/cache
ENV UDIFF_OUTPUT_DIR=/outputs

WORKDIR /app

COPY . /app

RUN pip install --no-cache-dir ".[api]"

EXPOSE 8000

CMD ["uvicorn", "service.fastapi_app.main:app", "--host", "0.0.0.0", "--port", "8000"]
